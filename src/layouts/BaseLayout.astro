---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

import playfair400 from '@fontsource/playfair-display/files/playfair-display-latin-400-normal.woff2?url';

interface Props {
	title: string;
	headerTheme?: 'dark' | 'light';
}

const { title, headerTheme = 'dark' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Compassionate, evidence-based wellness coaching for stress, anxiety, and burnout. Where lasting change begins." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#fdfaf5" />

        <link rel="preload" href={playfair400} as="font" type="font/woff2" crossorigin />

		<title>{title}</title>
	</head>
	<body class="antialiased font-sans overflow-x-hidden">
		<Header theme={headerTheme} />
		<slot />
		<Footer />
	</body>
</html>
