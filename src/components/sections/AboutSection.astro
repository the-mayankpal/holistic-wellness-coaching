---
import { Image } from 'astro:assets';
import aboutMaya from '../../assets/images/about-maya.png';
---

<section id="about" class="grid grid-cols-1 lg:grid-cols-2 w-full min-h-screen">
  
  <!-- Left Side: Image -->
  <div class="relative w-full h-[50vh] lg:h-auto overflow-hidden">
    <!-- Using Astro image optimization -->
    <Image 
      src={aboutMaya} 
      alt="Maya looking at the camera" 
      class="absolute inset-0 w-full h-full object-cover"
      format="webp"
    />
  </div>

  <!-- Right Side: Content -->
  <div class="bg-[#f5efe5] flex items-center justify-center px-8 sm:px-12 lg:px-20 py-20 lg:py-16">
    <div class="w-full max-w-[620px]">
      
      <!-- Badge -->
      <span class="inline-block bg-[#9c512c] text-white text-[13px] font-medium px-[1.1rem] py-[5px] rounded-full mb-8 tracking-wide">
        About me
      </span>

      <!-- Headline -->
      <h2 class="font-sans text-[48px] md:text-[56px] lg:text-[64px] font-normal tracking-tight text-[#2c2c2c] mb-5 leading-none">
        Hi, I'm <span class="text-[#9c512c]">Maya.</span>
      </h2>

      <!-- Subheadline -->
      <h3 class="text-[22px] md:text-[26px] font-medium leading-[1.3] text-[#3b3b3b] mb-10 tracking-tight max-w-[95%]">
        I help overwhelmed professionals find their way back to themselves.
      </h3>

      <!-- Body Copy -->
      <div class="text-[16px] text-[#6b6b6b] leading-[1.7] font-light space-y-6">
        <p>
          Five years ago, I was pulling 60-hour weeks and living on coffee, totally convinced I had it all figured out. Then my body had other ideas. Panic attacks, couldn't sleep, the whole mess.
        </p>
        <p>
          I've been there, and I know how isolating it feels. Now I help people find their way back to feeling like themselves again.
        </p>
      </div>

      <!-- Signature -->
      <div class="mt-12 text-[#2c2c2c]">
        <span class="font-script text-[72px] leading-none" style="font-family: 'Alex Brush', cursive;">Maya</span>
      </div>

    </div>
  </div>

</section>
