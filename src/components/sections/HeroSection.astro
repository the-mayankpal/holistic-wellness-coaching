---
import { Image } from 'astro:assets';
import heroBg from '../../assets/images/hero-bg.png';
import Button from '../ui/Button.astro';
---

<section class="relative min-h-screen w-full flex items-center pt-[100px] pb-12">
  <!-- Background Image with Astro Image Optimization -->
  <Image 
    src={heroBg} 
    alt="Soft glowing hand reaching towards the sun" 
    class="absolute inset-0 w-full h-full object-cover -z-20"
    loading="eager"
    format="webp"
  />
  
  <!-- Subtle dark gradient overlay to ensure text readability -->
  <div class="absolute inset-0 bg-gradient-to-r from-gray-900/60 via-gray-900/20 to-transparent -z-10"></div>

  <!-- Content Container -->
  <div class="max-w-[1400px] w-full mx-auto px-6 lg:px-12 relative z-10 text-white flex flex-col justify-center">
    
    <div class="max-w-2xl">
      <!-- Pill Badge -->
      <Button variant="glass" className="mb-6 pointer-events-none rounded-full px-5 py-2 font-medium tracking-wide">
        Mind &middot; Body &middot; Lifestyle
      </Button>

      <!-- Main Headline -->
      <h1 class="font-serif text-[72px] md:text-[96px] leading-[0.98] tracking-tight mb-5 mt-4">
        Where lasting<br />change begins.
      </h1>

      <!-- Subheadline -->
      <p class="text-[18px] md:text-[21px] text-white/90 font-light leading-relaxed mb-[3.25rem] max-w-[520px]">
        Compassionate, evidence-based wellness coaching for stress, anxiety, and burnout.
      </p>

      <!-- Action Buttons -->
      <div class="flex items-center gap-5 mb-24 lg:mb-32">
        <Button href="/contact" variant="primary-inverted">
          Begin Your Journey
        </Button>
        <Button href="/services" variant="primary">
          How I Can Help
        </Button>
      </div>

      <!-- Stats Row -->
      <div class="flex items-center text-white">
        
        <div class="flex flex-col pr-8 md:pr-[3.5rem]">
          <span class="text-[38px] md:text-[46px] font-medium tracking-tighter mb-1 leading-none">300+</span>
          <span class="text-[14px] font-light text-white/80 tracking-wide">Hours of Coaching</span>
        </div>
        
        <div class="w-[1px] h-[3.25rem] bg-white/40 hidden sm:block"></div>

        <div class="flex flex-col px-8 md:px-[3.5rem]">
          <span class="text-[38px] md:text-[46px] font-medium tracking-tighter mb-1 leading-none">200+</span>
          <span class="text-[14px] font-light text-white/80 tracking-wide">Client Sessions</span>
        </div>

        <div class="w-[1px] h-[3.25rem] bg-white/40 hidden sm:block"></div>

        <div class="flex flex-col pl-8 md:pl-[3.5rem]">
          <span class="text-[38px] md:text-[46px] font-medium tracking-tighter mb-1 leading-none">95%</span>
          <span class="text-[14px] font-light text-white/80 tracking-wide">Report Reduced Stress</span>
        </div>

      </div>
    </div>

  </div>
</section>
