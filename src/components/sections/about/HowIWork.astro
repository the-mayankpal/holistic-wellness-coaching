---
import { Image } from 'astro:assets';
import img1 from '../../../assets/images/about/how_i_work_1_1776543653582.png';
import img2 from '../../../assets/images/about/how_i_work_2_1776543670114.png';
import img3 from '../../../assets/images/about/how_i_work_3_1776543689266.png';
---

<section class="w-full bg-[#fbf9f4] py-24 md:py-[120px] px-8 text-center border-t border-[#f0ece5]">
    <div class="max-w-[1140px] mx-auto">
        
        <!-- Badge -->
        <span class="inline-block bg-[#f0ece5] text-[#55524d] text-[12px] font-medium tracking-wide rounded-full px-5 py-[5px] mb-8">
            How I Work
        </span>

        <!-- Title -->
        <h2 class="font-serif text-[42px] md:text-[52px] leading-[1.05] tracking-tight text-[#2b2b2b] mb-6">
            You don't need fixing,<br />
            you need <span class="text-[#b56733]">support.</span>
        </h2>

        <!-- Subtitle -->
        <p class="text-[#706c66] text-[15.5px] font-light max-w-[540px] mx-auto leading-relaxed mb-16">
            Most of the people I work with aren't broken. They're stretched too thin and have been ignoring their own needs for years.
        </p>

        <!-- Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-7 text-left mx-auto">
            
            <!-- Card 1 -->
            <div class="bg-[#f0ece5] rounded-[16px] overflow-hidden flex flex-col">
                <div class="w-full h-[300px] relative">
                    <Image src={img1} alt="Backed by research" class="w-full h-full object-cover" format="webp" />
                </div>
                <div class="px-7 py-8 pb-10 flex-grow flex flex-col">
                    <h3 class="text-[#2b2b2b] text-[18.5px] font-medium mb-2 tracking-tight">Backed by research</h3>
                    <p class="text-[#706c66] text-[14.5px] font-light leading-[1.6]">
                        No trendy recommendations. If the science isn't there, it's not here.
                    </p>
                </div>
            </div>

            <!-- Card 2 -->
            <div class="bg-[#f0ece5] rounded-[16px] overflow-hidden flex flex-col">
                <div class="w-full h-[300px] relative">
                    <Image src={img2} alt="No judgement, ever" class="w-full h-full object-cover" format="webp" />
                </div>
                <div class="px-7 py-8 pb-10 flex-grow flex flex-col">
                    <h3 class="text-[#2b2b2b] text-[18.5px] font-medium mb-2 tracking-tight">No judgement, ever</h3>
                    <p class="text-[#706c66] text-[14.5px] font-light leading-[1.6]">
                        You can say the real thing here. I'm not here to lecture you.
                    </p>
                </div>
            </div>

            <!-- Card 3 -->
            <div class="bg-[#f0ece5] rounded-[16px] overflow-hidden flex flex-col">
                <div class="w-full h-[300px] relative">
                    <Image src={img3} alt="The whole picture" class="w-full h-full object-cover" format="webp" />
                </div>
                <div class="px-7 py-8 pb-10 flex-grow flex flex-col">
                    <h3 class="text-[#2b2b2b] text-[18.5px] font-medium mb-2 tracking-tight">The whole picture</h3>
                    <p class="text-[#706c66] text-[14.5px] font-light leading-[1.6]">
                        Sleep, stress, food, work, relationships. It's all connected.
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>
