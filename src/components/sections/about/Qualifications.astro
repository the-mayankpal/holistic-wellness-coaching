---
---

<section class="w-full bg-[#FAF7F2] py-[100px] md:py-[140px] px-6 text-center flex flex-col items-center">
    
    <!-- Badge -->
    <div class="mb-8">
        <span class="inline-block bg-[#EBE4DC] text-[#68625d] text-[12px] font-medium tracking-wider uppercase rounded-full px-4 py-[6px]">
            Training
        </span>
    </div>

    <!-- Title -->
    <h2 class="font-sans font-medium text-[36px] md:text-[56px] leading-[1.05] tracking-[-0.03em] text-[#282725] mb-5">
        The qualifications that<br />
        <span class="text-[#A26442]">behind</span> the work.
    </h2>

    <!-- Subtitle -->
    <p class="text-[#68625d] text-[15px] md:text-[16px] font-light max-w-[480px] mx-auto leading-[1.65] mb-[70px]">
        Over 300 hours of formal training and eight years of working with real people going through real things.
    </p>

    <!-- Timeline Wrapper -->
    <div class="flex flex-col items-center w-full">
        
        <!-- Card 1 -->
        <div class="bg-[#F0EBE1] rounded-[24px] px-8 py-8 md:px-12 w-full max-w-[500px] flex items-center justify-start gap-8">
            <div class="font-serif italic text-[#A26442] text-[48px] md:text-[56px] tracking-[-0.03em] leading-none opacity-90">
                2019
            </div>
            <div class="flex flex-col items-start text-left">
                <h4 class="text-[#282725] text-[17px] md:text-[19px] font-medium mb-1 tracking-tight">Holistic Health Coach</h4>
                <p class="text-[#68625d] text-[14px] md:text-[14.5px] font-light mb-3">Institute for Integrative Nutrition</p>
                <span class="inline-block bg-[#E5DACE] text-[#A26442] text-[11px] font-medium tracking-wide uppercase rounded-full px-[14px] py-[4px]">Certified</span>
            </div>
        </div>

        <!-- Dotted Connector -->
        <div class="w-px h-8 my-1 flex flex-col justify-between py-1">
            <div class="w-[3px] h-[3px] rounded-full bg-[#A26442]/40 self-center"></div>
            <div class="w-[3px] h-[3px] rounded-full bg-[#A26442]/40 self-center"></div>
            <div class="w-[3px] h-[3px] rounded-full bg-[#A26442]/40 self-center"></div>
        </div>

        <!-- Card 2 -->
        <div class="bg-[#F0EBE1] rounded-[24px] px-8 py-8 md:px-12 w-full max-w-[500px] flex items-center justify-start gap-8">
            <div class="font-serif italic text-[#A26442] text-[48px] md:text-[56px] tracking-[-0.03em] leading-none opacity-90">
                2020
            </div>
            <div class="flex flex-col items-start text-left">
                <h4 class="text-[#282725] text-[17px] md:text-[19px] font-medium mb-1 tracking-tight">Stress Reduction (MBSR)</h4>
                <p class="text-[#68625d] text-[14px] md:text-[14.5px] font-light mb-3">UMass Medical School</p>
                <span class="inline-block bg-[#E5DACE] text-[#A26442] text-[11px] font-medium tracking-wide uppercase rounded-full px-[14px] py-[4px]">Certified</span>
            </div>
        </div>

        <!-- Dotted Connector -->
        <div class="w-px h-8 my-1 flex flex-col justify-between py-1">
            <div class="w-[3px] h-[3px] rounded-full bg-[#A26442]/40 self-center"></div>
            <div class="w-[3px] h-[3px] rounded-full bg-[#A26442]/40 self-center"></div>
            <div class="w-[3px] h-[3px] rounded-full bg-[#A26442]/40 self-center"></div>
        </div>

        <!-- Card 3 -->
        <div class="bg-[#F0EBE1] rounded-[24px] px-8 py-8 md:px-12 w-full max-w-[500px] flex items-center justify-start gap-8">
            <div class="font-serif italic text-[#A26442] text-[48px] md:text-[56px] tracking-[-0.03em] leading-none opacity-90">
                2021
            </div>
            <div class="flex flex-col items-start text-left">
                <h4 class="text-[#282725] text-[17px] md:text-[19px] font-medium mb-1 tracking-tight">Nutrition Practitioner</h4>
                <p class="text-[#68625d] text-[14px] md:text-[14.5px] font-light mb-3">National Academy<br/>of Sports Medicine</p>
                <span class="inline-block bg-[#E5DACE] text-[#A26442] text-[11px] font-medium tracking-wide uppercase rounded-full px-[14px] py-[4px]">Certified</span>
            </div>
        </div>

        <!-- Dotted Connector -->
        <div class="w-px h-8 my-1 flex flex-col justify-between py-1">
            <div class="w-[3px] h-[3px] rounded-full bg-[#A26442]/40 self-center"></div>
            <div class="w-[3px] h-[3px] rounded-full bg-[#A26442]/40 self-center"></div>
            <div class="w-[3px] h-[3px] rounded-full bg-[#A26442]/40 self-center"></div>
        </div>

        <!-- Card 4 -->
        <div class="bg-[#F0EBE1] rounded-[24px] px-8 py-8 md:px-12 w-full max-w-[500px] flex items-center justify-start gap-8">
            <div class="font-serif italic text-[#A26442] text-[48px] md:text-[56px] tracking-[-0.03em] leading-none opacity-90">
                2022
            </div>
            <div class="flex flex-col items-start text-left">
                <h4 class="text-[#282725] text-[17px] md:text-[19px] font-medium mb-1 tracking-tight">Trauma-Informed Care</h4>
                <p class="text-[#68625d] text-[14px] md:text-[14.5px] font-light mb-3">Somatic Experiencing International</p>
                <span class="inline-block bg-[#E5DACE] text-[#A26442] text-[11px] font-medium tracking-wide uppercase rounded-full px-[14px] py-[4px]">Certified</span>
            </div>
        </div>

    </div>

</section>
