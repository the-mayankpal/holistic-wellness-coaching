---
interface Props {
  variant?: 'primary' | 'primary-inverted' | 'secondary' | 'glass';
  href?: string;
  className?: string;
  type?: "button" | "submit" | "reset";
}

const { 
  variant = 'primary', 
  href, 
  className = '',
  type = "button"
} = Astro.props;

const baseStyles = "inline-flex items-center justify-center font-medium rounded-full transition-all duration-300 ease-out whitespace-nowrap text-[15px] tracking-wide";

const variants = {
  primary: "bg-[#a85a32] text-white hover:bg-[#8b4a29] px-8 py-[14px]",
  'primary-inverted': "bg-white text-[#2b3333] hover:bg-gray-100 px-8 py-[14px]",
  secondary: "bg-transparent text-white border border-white hover:bg-white/10 px-8 py-[14px]",
  glass: "bg-white/20 backdrop-blur-md text-white border border-white/20 px-5 py-[8px] text-[13px] font-medium tracking-widest", 
};

const Tag = href ? "a" : "button";
const props = href ? { href } : { type };
---

<Tag 
  {...props} 
  class={`${baseStyles} ${variants[variant]} ${className}`}
>
  <slot />
</Tag>
