---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  imageSrc: any; // Allow metadata or string URL
}

const { title, description, imageSrc } = Astro.props;
const isRemote = typeof imageSrc === 'string';
---

<div class="flex flex-col bg-[#efeae0] rounded-[1.25rem] overflow-hidden shadow-sm transition-transform duration-300 hover:scale-[1.01]">
  <!-- Image Header -->
  <div class="w-full aspect-square relative">
    {isRemote ? (
      <img 
        src={imageSrc} 
        alt={title} 
        class="absolute inset-0 w-full h-full object-cover" 
        loading="lazy"
      />
    ) : (
      <Image 
        src={imageSrc} 
        alt={title} 
        class="absolute inset-0 w-full h-full object-cover" 
        format="webp" 
      />
    )}
  </div>
  
  <!-- Content Body -->
  <div class="flex flex-col p-6 pt-5 pb-7 h-full text-left">
    <h3 class="text-[#2c2c2c] text-[20px] font-medium tracking-tight mb-2">
      {title}
    </h3>
    <p class="text-[#6b6b6b] text-[14.5px] font-light leading-relaxed">
      {description}
    </p>
  </div>
</div>
