---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<faq-item class="block mb-4">
  <div class="bg-[#f0ebd9] rounded-2xl overflow-hidden shadow-[0_2px_10px_rgba(0,0,0,0.02)] transition-colors duration-300">
    <button class="w-full flex items-center justify-between text-left py-6 px-8 cursor-pointer focus:outline-none">
      <h3 class="text-[#2c2c2c] text-[16px] md:text-[17px] font-medium pr-8">{question}</h3>
      <div class="icon-wrapper shrink-0 text-[#2c2c2c] transition-transform duration-300">
        <!-- Plus Icon -->
        <svg class="plus-icon w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
      </div>
    </button>
    <div class="answer-wrapper grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out">
      <div class="overflow-hidden">
        <p class="px-8 pb-6 text-[#646464] text-[15px] font-light leading-relaxed">
          {answer}
        </p>
      </div>
    </div>
  </div>
</faq-item>

<script>
  class FAQItem extends HTMLElement {
    constructor() {
      super();
      let isOpen = false;
      const button = this.querySelector('button');
      const answerWrapper = this.querySelector('.answer-wrapper');
      const iconWrapper = this.querySelector('.icon-wrapper');

      button?.addEventListener('click', () => {
        isOpen = !isOpen;
        
        // Toggle structural height via CSS Grid
        if (answerWrapper) {
          if (isOpen) {
            answerWrapper.classList.remove('grid-rows-[0fr]');
            answerWrapper.classList.add('grid-rows-[1fr]');
          } else {
            answerWrapper.classList.remove('grid-rows-[1fr]');
            answerWrapper.classList.add('grid-rows-[0fr]');
          }
        }

        // Rotate Icon
        if (iconWrapper) {
          if (isOpen) {
            iconWrapper.classList.add('rotate-45');
          } else {
            iconWrapper.classList.remove('rotate-45');
          }
        }
      });
    }
  }

  customElements.define('faq-item', FAQItem);
</script>
