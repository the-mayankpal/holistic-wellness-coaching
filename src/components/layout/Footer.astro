---
import Button from '../ui/Button.astro';
import Logo from '../common/Logo.astro';
import PopupModal from '../ui/PopupModal.astro';
---

<footer class="w-full bg-[#f5efe5] pt-24 pb-10 border-t border-[#e8dfd5]/50">
  <div class="max-w-[1100px] mx-auto px-6 sm:px-10 lg:px-12">

    <!-- CTA Block -->
    <div class="flex flex-col items-center text-center mb-24">
      
      <!-- Geometric Logo -->
      <div class="mb-8">
        <Logo size={56} class="text-[#9c512c]" />
      </div>

      <!-- Headline -->
      <h2 class="font-sans text-[38px] md:text-[52px] font-normal tracking-tight text-[#2c2c2c] leading-[1.1] mb-6">
        You deserve to feel like<br />
        <span class="text-[#9c512c]">yourself</span> again.
      </h2>

      <!-- Subheading -->
      <p class="text-[16.5px] text-[#666] font-light leading-relaxed mb-10 max-w-sm">
        Book a free discovery call and let's talk about what's weighing you down.
      </p>

      <!-- CTA Button -->
      <Button href="/contact" variant="primary">
        Begin Your Journey
      </Button>

    </div>

    <!-- Links Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-12 sm:gap-8 mb-20 border-t border-[#e0d8cc]/60 pt-16">

      <!-- Navigate -->
      <div>
        <h4 class="text-[#2c2c2c] text-[14px] font-semibold tracking-wide mb-6">Navigate</h4>
        <ul class="flex flex-col gap-4">
          {["Home", "About", "Services", "Journal"].map(link => (
            <li>
              <a href={`/${link.toLowerCase() === 'home' ? '' : link.toLowerCase()}`} 
                 class="text-[#888] text-[14px] font-light hover:text-[#9c512c] transition-colors duration-200">
                {link}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="text-[#2c2c2c] text-[14px] font-semibold tracking-wide mb-6">Connect</h4>
        <ul class="flex flex-col gap-4">
          {[
            { label: "Book a Call", href: "/contact" },
            { label: "Twitter", href: "https://twitter.com" },
            { label: "Instagram", href: "https://instagram.com" },
            { label: "Meta", href: "https://facebook.com" }
          ].map(link => (
            <li>
              <a href={link.href} 
                 class="text-[#888] text-[14px] font-light hover:text-[#9c512c] transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-[#2c2c2c] text-[14px] font-semibold tracking-wide mb-6">Legal</h4>
        <ul class="flex flex-col gap-4">
          {[
            { label: "Privacy Policy", href: "/privacy" },
            { label: "Terms of Service", href: "/terms" }
          ].map(link => (
            <li>
              <a href={link.href} 
                 class="text-[#888] text-[14px] font-light hover:text-[#9c512c] transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between pt-6 border-t border-[#e0d8cc]/60 gap-4">
      <span class="text-[#aaa] text-[13px] font-light">© 2026 Holistic. All rights reserved.</span>
      <span class="text-[#aaa] text-[13px] font-light">Created by Mayan K</span>

    </div>

  </div>
  
  <!-- Global Popup triggers natively across all views since footer wraps all views -->
  <PopupModal />
</footer>
