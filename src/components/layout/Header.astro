---
import Button from '../ui/Button.astro';
import Logo from '../common/Logo.astro';

interface Props {
  theme?: 'dark' | 'light';
}

const { theme = 'dark' } = Astro.props;
---

<header id="site-header" class={`site-header ${theme === 'light' ? 'theme-light' : ''}`} data-theme={theme}>
  <div class="header-inner">
    
    <!-- Logo (always visible, left on mobile, center on desktop) -->
    <a href="/" class="header-logo-link">
      <Logo id="header-logo" size={56} class="transition-colors duration-300" />
    </a>

    <!-- Desktop Navigation -->
    <nav class="desktop-nav">
      <a href="/" class="nav-link">Home</a>
      <a href="/about" class="nav-link">About</a>
      <a href="/services" class="nav-link">Services</a>
      <a href="/journal" class="nav-link">Journal</a>
    </nav>

    <!-- Desktop CTA -->
    <div class="desktop-cta">
      <Button href="/contact" variant="primary" className="!px-6 !py-[10px] !text-[13px] tracking-wide">Begin Your Journey</Button>
    </div>

    <!-- Hamburger (mobile only) -->
    <button id="mobile-menu-toggle" class="hamburger-btn" aria-label="Toggle Menu">
      <svg id="hamburger-icon" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" y1="8" x2="20" y2="8"></line>
        <line x1="4" y1="16" x2="20" y2="16"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile Dropdown -->
  <div id="mobile-dropdown" class="mobile-dropdown">
    <a href="/" class="mobile-link">Home</a>
    <a href="/about" class="mobile-link">About</a>
    <a href="/services" class="mobile-link">Services</a>
    <a href="/journal" class="mobile-link">Journal</a>
    <a href="/contact" class="mobile-cta-link">Begin Your Journey</a>
  </div>
</header>

<style>
  /* ===== BASE HEADER ===== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 9999;
    transition: background 0.3s, box-shadow 0.3s, padding 0.3s;
    padding: 28px 0;
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }

  .header-logo-link {
    display: block;
    z-index: 100;
    color: rgba(255, 255, 255, 0.9);
    transition: opacity 0.2s;
    line-height: 0;
  }
  .header-logo-link:hover { opacity: 0.8; }

  /* ===== DESKTOP NAV ===== */
  .desktop-nav {
    display: none;
    align-items: center;
    gap: 28px;
    font-size: 15px;
    font-weight: 300;
    letter-spacing: 0.03em;
    color: white;
  }
  .desktop-nav .nav-link {
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
  }
  .desktop-nav .nav-link:hover { opacity: 0.7; }

  .desktop-cta {
    display: none;
  }

  /* ===== HAMBURGER ===== */
  .hamburger-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 100;
    color: white;
    transition: color 0.3s;
  }

  /* ===== MOBILE DROPDOWN ===== */
  .mobile-dropdown {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.25s ease;
    background: #fdfaf5;
    border-top: 1px solid #ebe4da;
    box-shadow: 0 12px 30px rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    padding: 0 20px;
  }
  .mobile-dropdown.is-open {
    max-height: 380px;
    opacity: 1;
    padding: 24px 20px;
  }

  .mobile-link {
    text-decoration: none;
    color: #2c2c2c;
    font-size: 17px;
    font-weight: 400;
    padding: 10px 0;
    transition: color 0.2s;
    letter-spacing: 0.01em;
  }
  .mobile-link:hover { color: #9c512c; }

  .mobile-cta-link {
    display: block;
    text-align: center;
    margin-top: 16px;
    background-color: #9c512c;
    color: white;
    text-decoration: none;
    padding: 13px 24px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    transition: opacity 0.2s;
  }
  .mobile-cta-link:hover { opacity: 0.9; }

  /* ===== DESKTOP (768px+) ===== */
  @media (min-width: 768px) {
    .site-header {
      padding: 28px 0;
    }
    .header-inner {
      padding: 0 48px;
    }
    .header-logo-link {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }
    .desktop-nav {
      display: flex;
    }
    .desktop-cta {
      display: flex;
      align-items: center;
    }
    .hamburger-btn {
      display: none;
    }
    .mobile-dropdown {
      display: none !important;
    }
  }

  /* ===== SCROLLED STATE (set by JS) ===== */
  .site-header.is-scrolled {
    background: rgba(253, 250, 245, 0.97);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 1px 24px rgba(0,0,0,0.06);
    padding: 16px 0;
  }
  .site-header.is-scrolled .header-logo-link {
    color: #9c512c;
  }
  .site-header.is-scrolled .desktop-nav {
    color: #2c2c2c;
  }
  .site-header.is-scrolled .hamburger-btn {
    color: #2c2c2c;
  }

  /* Menu-open state (set by JS) */
  .site-header.menu-open {
    background: rgba(253, 250, 245, 0.97);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }
  .site-header.menu-open .header-logo-link {
    color: #9c512c;
  }
  .site-header.menu-open .hamburger-btn {
    color: #2c2c2c;
  }

  /* ===== LIGHT THEME (inner pages with light backgrounds) ===== */
  .site-header.theme-light .header-logo-link {
    color: #9c512c;
  }
  .site-header.theme-light .desktop-nav {
    color: #2c2c2c;
  }
  .site-header.theme-light .hamburger-btn {
    color: #2c2c2c;
  }
</style>

<script is:inline>
  (function () {
    var header = document.getElementById('site-header');
    var logo = document.getElementById('header-logo');
    var toggleBtn = document.getElementById('mobile-menu-toggle');
    var dropdown = document.getElementById('mobile-dropdown');
    var theme = header.getAttribute('data-theme');
    var heroHeight = theme === 'light' ? 50 : window.innerHeight * 0.6;
    var isOpen = false;

    function openMenu() {
      isOpen = true;
      dropdown.classList.add('is-open');
      header.classList.add('menu-open');
      toggleBtn.innerHTML = '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>';
    }

    function closeMenu() {
      isOpen = false;
      dropdown.classList.remove('is-open');
      header.classList.remove('menu-open');
      toggleBtn.innerHTML = '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="8" x2="20" y2="8"></line><line x1="4" y1="16" x2="20" y2="16"></line></svg>';
      handleScroll();
    }

    if (toggleBtn) {
      toggleBtn.addEventListener('click', function () {
        if (isOpen) { closeMenu(); } else { openMenu(); }
      });
    }

    // Close on link click
    var mobileLinks = dropdown.querySelectorAll('.mobile-link');
    for (var i = 0; i < mobileLinks.length; i++) {
      mobileLinks[i].addEventListener('click', closeMenu);
    }

    function handleScroll() {
      if (isOpen) return;
      if (window.scrollY > heroHeight) {
        header.classList.add('is-scrolled');
      } else {
        header.classList.remove('is-scrolled');
      }
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
  })();
</script>
