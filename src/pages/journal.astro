import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import Button from '../components/ui/Button.astro';
import { sanityClient } from "sanity:client";

const posts = await sanityClient.fetch(`*[_type == "post"] | order(date desc) {
  title,
  excerpt,
  category,
  date,
  readTime,
  "imageUrl": mainImage.asset->url
}`);

const initialPosts = posts.slice(0, 3);
const hiddenPosts = posts.slice(3);
---

<BaseLayout title="Journal | Mayan K Wellness" headerTheme="light">
    
    <!-- HERO SECTION -->
    <div class="relative w-full flex flex-col justify-start" style="background-color: #f4ebd9; padding-top: 154px; padding-bottom: 120px;">
        
        <!-- HERO CONTENT -->
        <main class="w-full flex flex-col items-center justify-center text-center px-6 relative z-20" style="padding-top: 40px;">
            
            <!-- Badge -->
            <span class="inline-block font-medium tracking-wide rounded-full shadow-sm" style="background-color: #9c512c; color: white; padding: 6px 20px; font-size: 12px; margin-bottom: 28px;">
                Journal
            </span>
            
            <!-- Headline -->
            <h1 class="font-serif font-normal" style="color: #2c3338; font-size: clamp(42px, 7vw, 72px); line-height: 1; letter-spacing: -0.02em; margin-bottom: 24px;">
                Writing from the<br/>
                <span style="color: #bc6b3c; font-style: italic;">other side</span> of burnout.
            </h1>
            
            <!-- Subtitle -->
            <p class="font-light" style="color: #55524d; font-size: 16px; line-height: 1.65; max-width: 440px;">
                Honest writing about the things I see in my<br class="hidden md:block"/>
                practice and the lessons I keep coming back to.
            </p>
            
        </main>
    </div>

    <!-- JOURNAL FEED SECTION -->
    <section class="w-full relative flex flex-col items-center px-6" style="background-color: #fcfbfa; padding-top: 80px; padding-bottom: 120px;">
        <div class="w-full" style="max-width: 1140px;">
            
            <!-- Filter Pills -->
            <div class="flex items-center gap-3" style="margin-bottom: 40px;">
                <span class="inline-block" style="background-color: #9c512c; color: white; padding: 7px 22px; border-radius: 9999px; font-size: 13px; font-medium; box-shadow: 0 4px 10px rgba(156,81,44,0.15);">
                    All
                </span>
            </div>

            <!-- Articles Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 w-full text-left" style="gap: 28px;">
                
                <!-- Initial Posts -->
                {initialPosts.map((post) => (
                    <div class="flex flex-col relative group cursor-pointer" style="background-color: #f1ebd9; border-radius: 14px; overflow: hidden; transition: transform 0.3s ease;">
                        <div class="w-full relative overflow-hidden flex-shrink-0" style="height: 240px;">
                            <img src={post.imageUrl} alt={post.title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" />
                        </div>
                        <div class="flex flex-col items-start w-full flex-grow" style="padding: 30px 28px 34px 28px; flex-grow: 1;">
                            <span style="background-color: #faeedf; color: #a35d3d; font-size: 11px; font-weight: 500; padding: 4px 12px; border-radius: 99px; margin-bottom: 16px; letter-spacing: 0.02em;">
                                {post.category}
                            </span>
                            <h3 class="font-medium" style="color: #2c3338; font-size: 19px; line-height: 1.25; letter-spacing: -0.01em; margin-bottom: 14px;">
                                {post.title}
                            </h3>
                            <p class="font-light" style="color: #635f5a; font-size: 13.5px; line-height: 1.6; margin-bottom: 32px;">
                                {post.excerpt}
                            </p>
                            <div class="flex items-center font-light w-full" style="color: #8c8882; font-size: 12px; margin-top: auto;">
                                {post.date} <span class="mx-2">&bull;</span> {post.readTime}
                            </div>
                        </div>
                    </div>
                ))}

                <!-- Hidden Posts -->
                {hiddenPosts.map((post) => (
                    <div class="hidden-card relative group cursor-pointer" style="display: none; flex-direction: column; background-color: #f1ebd9; border-radius: 14px; overflow: hidden; transition: transform 0.3s ease;">
                        <div class="w-full relative overflow-hidden flex-shrink-0" style="height: 240px;">
                            <img src={post.imageUrl} alt={post.title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" />
                        </div>
                        <div class="flex flex-col items-start w-full flex-grow" style="padding: 30px 28px 34px 28px; flex-grow: 1;">
                            <span style="background-color: #faeedf; color: #a35d3d; font-size: 11px; font-weight: 500; padding: 4px 12px; border-radius: 99px; margin-bottom: 16px; letter-spacing: 0.02em;">
                                {post.category}
                            </span>
                            <h3 class="font-medium" style="color: #2c3338; font-size: 19px; line-height: 1.25; letter-spacing: -0.01em; margin-bottom: 14px;">
                                {post.title}
                            </h3>
                            <p class="font-light" style="color: #635f5a; font-size: 13.5px; line-height: 1.6; margin-bottom: 32px;">
                                {post.excerpt}
                            </p>
                            <div class="flex items-center font-light w-full" style="color: #8c8882; font-size: 12px; margin-top: auto;">
                                {post.date} <span class="mx-2">&bull;</span> {post.readTime}
                            </div>
                        </div>
                    </div>
                ))}

            </div>

            <!-- Load More Button -->
            <div class="w-full flex justify-center" style="margin-top: 60px;">
                <button id="load-more-btn" style="background-color: #9c512c; color: white; padding: 11px 32px; border-radius: 9999px; font-size: 13px; font-weight: 500; border: none; cursor: pointer; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
                    Load More
                </button>
            </div>

            <!-- Newsletter Section -->
            <div class="w-full flex flex-col md:flex-row items-center justify-between" style="background-color: #f4ebd9; border-radius: 16px; padding: 32px 28px; margin-top: 100px;">
                
                <!-- Text Area (Left) -->
                <div class="text-left mb-6 md:mb-0 max-w-lg">
                    <h3 class="font-medium" style="color: #2c3338; font-size: 26px; letter-spacing: -0.02em; margin-bottom: 6px;">
                        Get new posts straight to your inbox.
                    </h3>
                    <p class="font-light" style="color: #635f5a; font-size: 15px;">
                        No spam, no fluff. Just honest writing when I have something worth sharing.
                    </p>
                </div>

                <!-- Input Area (Right) -->
                <div style="background-color: white; border-radius: 9999px; padding: 6px 6px 6px 24px; display: flex; align-items: center; width: 100%; max-width: 400px; box-shadow: 0 4px 15px rgba(0,0,0,0.03);">
                    <input type="email" placeholder="Enter your email" class="font-light w-full" style="background: transparent; border: none; outline: none; font-size: 14.5px; color: #555; font-family: 'Inter', sans-serif; min-width: 0;" />
                    <button style="background-color: #9c512c; color: white; padding: 12px 24px; border-radius: 9999px; font-size: 14px; font-weight: 500; border: none; cursor: pointer; white-space: nowrap; transition: opacity 0.2s; flex-shrink: 0;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
                        Subscribe
                    </button>
                </div>

            </div>

        </div>
    </section>

    <!-- LOAD MORE SCRIPT -->
    <script is:inline>
        (function () {
            var loadMoreBtn = document.getElementById('load-more-btn');
            if (loadMoreBtn) {
                loadMoreBtn.addEventListener('click', function() {
                    var hiddenCards = document.querySelectorAll('.hidden-card');
                    hiddenCards.forEach(function(card) {
                        card.style.display = 'flex';
                    });
                    loadMoreBtn.style.display = 'none';
                });
            }
        })();
    </script>

</BaseLayout>
