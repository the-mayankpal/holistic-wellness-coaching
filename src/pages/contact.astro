---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import Button from '../components/ui/Button.astro';

import aboutMaya from '../assets/images/aboutpageimage.png'; 

const CalendarIcon = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9c512c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>`;
---

<BaseLayout 
    title="Contact | Mayan K Wellness" 
    description="Book a free discovery call or send a message to start your journey toward balance and mental clarity. Let's have a conversation."
    headerTheme="light"
>

    <!-- SPLIT HERO SECTION -->
    <div style="width: 100%; display: flex; flex-direction: row; flex-wrap: wrap; position: relative; z-index: 10; min-height: 90vh;">
        
        <!-- Left Text Content -->
        <div style="width: 50%; min-width: 300px; flex-grow: 1; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; padding: 128px 8% 80px 8%; background-color: #f4ebd9; box-sizing: border-box;">
            
            <span style="display: inline-block; font-weight: 500; letter-spacing: 0.02em; border-radius: 9999px; background-color: #9c512c; color: white; padding: 6px 20px; font-size: 12px; margin-bottom: 32px; font-family: 'Inter', sans-serif;">
                Contact
            </span>
            
            <h1 class="contact-hero-heading" style="font-family: 'Playfair Display', serif; font-weight: 400; color: #2c3338; font-size: 76px; line-height: 0.95; letter-spacing: -0.02em; margin-bottom: 28px;">
                Let's have a<br/>
                <span style="color: #bc6b3c;">conversation.</span>
            </h1>
            
            <p style="font-family: 'Inter', sans-serif; font-weight: 300; color: #635f5a; font-size: 16px; line-height: 1.65; max-width: 440px;">
                Whether you're ready to book a session or just want to ask a question, this is the place. No pressure, no obligations.
            </p>

            <!-- Signature -->
            <div style="margin-top: 42px;">
               <span style="font-family: 'Alex Brush', cursive; color: #2c3338; font-size: 84px; line-height: 1;">Maya</span>
            </div>
        </div>

        <!-- Right Image Content -->
        <div style="width: 50%; min-width: 320px; flex-grow: 1; position: relative; min-height: 60vh;">
            <Image src={aboutMaya} alt="Maya" class="absolute inset-0 w-full h-full" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;" />
        </div>
        
    </div>

    <!-- CONTACT OPTIONS SECTION -->
    <section style="width: 100%; display: flex; justify-content: center; padding: 80px 20px; background-color: #fcfbfa; box-sizing: border-box;">
        <div style="width: 100%; max-width: 1240px; display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 400px), 1fr)); gap: 40px; box-sizing: border-box;">
            
            <!-- LEFT PANEL: Calender Pick -->
            <div style="background-color: #f4ebd9; border-radius: 24px; padding: 40px 28px; display: flex; flex-direction: column; box-sizing: border-box;">
                
                <span style="display: inline-block; background-color: white; color: #55524d; padding: 5px 16px; border-radius: 99px; font-size: 11px; font-weight: 500; font-family: 'Inter', sans-serif; align-self: flex-start; margin-bottom: 24px;">
                    Book a free session
                </span>
                
                <h2 style="color: #2c3338; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 12px; font-family: 'Inter', sans-serif; font-weight: 500;">
                    Pick a time that<br/>
                    works <span style="color: #9c512c;">for you.</span>
                </h2>

                <p style="color: #635f5a; font-size: 14.5px; line-height: 1.6; margin-bottom: 40px; max-width: 320px; font-family: 'Inter', sans-serif; font-weight: 300;">
                    Free 20-minute discovery calls. No commitment, just a conversation about where you're at.
                </p>

                <!-- Embed Calendar Module Placeholder Container -->
                <div style="width: 100%; display: flex; flex-direction: column; items-center; justify-content: center; text-align: center; background-color: #ffffff; border-radius: 16px; padding: 40px; margin-bottom: 20px; box-sizing: border-box;">
                    <div style="align-self: center; background-color: #f4ebd9; padding: 12px; border-radius: 12px; margin-bottom: 16px;">
                        <span set:html={CalendarIcon} />
                    </div>
                    <h3 style="color: #2c3338; font-size: 18px; margin-bottom: 8px; font-family: 'Inter', sans-serif; font-weight: 500;">Embed your calendar</h3>
                    <p style="color: #8c8882; font-size: 13px; line-height: 1.5; margin: 0 auto 32px auto; max-width: 260px; font-family: 'Inter', sans-serif; font-weight: 300;">
                        Embed your calendar here so your visitors can pick a date, time, and book directly.
                    </p>

                    <!-- Static Pill Row visual matching -->
                    <div style="display: flex; align-items: center; justify-content: center; gap: 12px;">
                        <span style="background-color: #fdfbfa; color: #a35d3d; font-size: 13px; font-weight: 500; padding: 12px 16px; border-radius: 10px; opacity: 0.5; font-family: 'Inter', sans-serif;">14</span>
                        <span style="background-color: #fdfbfa; color: #a35d3d; font-size: 13px; font-weight: 500; padding: 12px 16px; border-radius: 10px; opacity: 0.5; font-family: 'Inter', sans-serif;">15</span>
                        <span style="background-color: #f4ebd9; color: #9c512c; font-size: 14px; font-weight: 600; padding: 14px 20px; border-radius: 12px; box-shadow: 0 4px 12px rgba(156,81,44,0.1); font-family: 'Inter', sans-serif;">16</span>
                        <span style="background-color: #fdfbfa; color: #a35d3d; font-size: 13px; font-weight: 500; padding: 12px 16px; border-radius: 10px; opacity: 0.5; font-family: 'Inter', sans-serif;">17</span>
                        <span style="background-color: #fdfbfa; color: #a35d3d; font-size: 13px; font-weight: 500; padding: 12px 16px; border-radius: 10px; opacity: 0.5; font-family: 'Inter', sans-serif;">18</span>
                    </div>
                </div>

                <!-- Call Type Listing 1 -->
                <div style="width: 100%; display: flex; flex-direction: column; justify-content: center; background-color: #ffffff; border-radius: 14px; padding: 22px 28px; margin-bottom: 16px; box-sizing: border-box;">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 4px;">
                        <span style="width: 10px; height: 10px; border-radius: 50%; background-color: #9c512c; display: inline-block;"></span>
                        <span style="color: #2c3338; font-size: 14.5px; font-family: 'Inter', sans-serif; font-weight: 500;">Discovery call</span>
                    </div>
                    <div style="color: #8c8882; font-size: 13px; margin-left: 22px; font-family: 'Inter', sans-serif; font-weight: 300;">
                        20 min &bull; Free
                    </div>
                </div>

                <!-- Call Type Listing 2 -->
                <div style="width: 100%; display: flex; flex-direction: column; justify-content: center; background-color: #ffffff; border-radius: 14px; padding: 22px 28px; box-sizing: border-box;">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 4px;">
                        <span style="width: 10px; height: 10px; border-radius: 50%; background-color: #dedad5; display: inline-block;"></span>
                        <span style="color: #55524d; font-size: 14.5px; font-family: 'Inter', sans-serif; font-weight: 500;">Full session</span>
                    </div>
                    <div style="color: #8c8882; font-size: 13px; margin-left: 22px; font-family: 'Inter', sans-serif; font-weight: 300;">
                        60 min &bull; Existing clients
                    </div>
                </div>

            </div>

            <!-- RIGHT PANEL: Direct Message Form -->
            <div style="background-color: #f4ebd9; border-radius: 24px; padding: 40px 28px; display: flex; flex-direction: column; box-sizing: border-box;">
                
                <span style="display: inline-block; background-color: #9c512c; color: white; padding: 5px 16px; border-radius: 99px; font-size: 11px; font-weight: 500; font-family: 'Inter', sans-serif; align-self: flex-start; margin-bottom: 24px;">
                    Get in touch
                </span>
                
                <h2 style="color: #2c3338; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 12px; font-family: 'Inter', sans-serif; font-weight: 500;">
                    Or send me a<br/>
                    <span style="color: #9c512c;">message.</span>
                </h2>

                <p style="color: #635f5a; font-size: 14.5px; line-height: 1.6; margin-bottom: 40px; max-width: 320px; font-family: 'Inter', sans-serif; font-weight: 300;">
                    I read every message personally and reply within 48 hours (usually less).
                </p>

                <!-- Form -->
                <form style="display: flex; flex-direction: column; width: 100%; font-family: 'Inter', sans-serif;" action="#" method="POST">
                    
                    <!-- Name Field -->
                    <div style="display: flex; flex-direction: column; margin-bottom: 20px;">
                        <label for="name" style="color: #55524d; font-size: 13.5px; margin-bottom: 8px; font-weight: 300;">Name</label>
                        <input type="text" id="name" name="name" placeholder="Your Name" required style="background-color: #ffffff; border: none; outline: none; padding: 16px 20px; border-radius: 12px; font-size: 14px; color: #333; font-weight: 300; font-family: 'Inter', sans-serif;" />
                    </div>

                    <!-- Email Field -->
                    <div style="display: flex; flex-direction: column; margin-bottom: 20px;">
                        <label for="email" style="color: #55524d; font-size: 13.5px; margin-bottom: 8px; font-weight: 300;">Email</label>
                        <input type="email" id="email" name="email" placeholder="your@email.com" required style="background-color: #ffffff; border: none; outline: none; padding: 16px 20px; border-radius: 12px; font-size: 14px; color: #333; font-weight: 300; font-family: 'Inter', sans-serif;" />
                    </div>

                    <!-- Subject Field -->
                    <div style="display: flex; flex-direction: column; margin-bottom: 20px;">
                        <label for="subject" style="color: #55524d; font-size: 13.5px; margin-bottom: 8px; font-weight: 300;">Subject</label>
                        <input type="text" id="subject" name="subject" placeholder="What is this about?" style="background-color: #ffffff; border: none; outline: none; padding: 16px 20px; border-radius: 12px; font-size: 14px; color: #333; font-weight: 300; font-family: 'Inter', sans-serif;" />
                    </div>

                    <!-- Message Field -->
                    <div style="display: flex; flex-direction: column; margin-bottom: 32px;">
                        <label for="message" style="color: #55524d; font-size: 13.5px; margin-bottom: 8px; font-weight: 300;">Message</label>
                        <textarea id="message" name="message" rows="5" placeholder="Tell me what's on your mind..." required style="background-color: #ffffff; border: none; outline: none; padding: 16px 20px; border-radius: 12px; font-size: 14px; color: #333; font-weight: 300; resize: vertical; min-height: 120px; font-family: 'Inter', sans-serif; line-height: 1.6;"></textarea>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" style="background-color: #9c512c; color: white; padding: 16px 24px; border-radius: 9999px; font-size: 14.5px; font-weight: 500; border: none; cursor: pointer; transition: opacity 0.2s; width: 100%; font-family: 'Inter', sans-serif;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
                        Send a message
                    </button>

                </form>

            </div>

        </div>
    </section>

    <style>
        @media (max-width: 640px) {
            .contact-hero-heading {
                font-size: 48px !important;
            }
        }
    </style>

</BaseLayout>
