---
import '../styles/global.css';
import { Image } from 'astro:assets';
import Button from '../components/ui/Button.astro';
import Footer from '../components/layout/Footer.astro';
import Logo from '../components/common/Logo.astro';

// Import newly generated components for the extended sections
import WhatToExpect from '../components/sections/services/WhatToExpect.astro';
import ProgramsSection from '../components/sections/ProgramsSection.astro';
import FAQSection from '../components/sections/FAQSection.astro';

// Import newly generated images
import imgStress from '../assets/images/services/stress_anxiety_banner_1776545689108.png';
import imgBurnout from '../assets/images/services/burnout_recovery_banner_1776545703294.png';
import imgTransitions from '../assets/images/services/life_transitions_banner_1776545720609.png';
import imgMindful from '../assets/images/services/mindful_living_banner_1776545736355.png';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Alex+Brush&family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
		<title>Services | Mayan K Wellness</title>
	</head>
	<body class="antialiased font-sans bg-white overflow-x-hidden relative flex flex-col">
		
        <!-- HERO SECTION -->
        <div class="relative w-full flex flex-col justify-start" style="background-color: #f4ebd9; padding-top: 140px; padding-bottom: 120px;">
            
            <!-- NAVBAR -->
            <header id="services-header" class="fixed top-0 left-0 w-full z-50 pt-8 pb-5 transition-all duration-300">
                <div class="max-w-7xl mx-auto px-6 lg:px-12 flex items-center justify-between relative">
                    
                    <!-- Left Navigation -->
                    <nav class="hidden md:flex items-center gap-8 text-sm font-medium tracking-wide" style="color: #2c2c2c;">
                        <a href="/" class="transition-colors hover:opacity-75">Home</a>
                        <a href="/about" class="transition-colors hover:opacity-75">About</a>
                        <a href="/services" class="transition-colors hover:opacity-75">Services</a>
                        <a href="/journal" class="transition-colors hover:opacity-75">Journal</a>
                    </nav>

                    <!-- Mobile Hamburger -->
                    <button id="services-menu-toggle" class="md:hidden flex items-center justify-center p-2 z-[60] text-[#2c2c2c] transition-colors" aria-label="Toggle Menu">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="4" y1="8" x2="20" y2="8"></line>
                            <line x1="4" y1="16" x2="20" y2="16"></line>
                        </svg>
                    </button>

                    <!-- Center Logo -->
                    <div class="absolute left-1/2 -translate-x-1/2 mt-1 z-[60]">
                        <a href="/" class="block hover:opacity-70 transition-opacity" style="color: #2c2c2c;">
                            <Logo id="header-logo" size={54} />
                        </a>
                    </div>

                    <!-- Right Actions -->
                    <div class="hidden md:flex items-center">
                        <Button href="/contact" variant="primary" className="!px-7 !py-3 !text-sm font-medium opacity-95 shadow-sm border-none" style="background-color: #9c512c; color: white;">
                            Begin Your Journey
                        </Button>
                    </div>
                </div>

                <!-- Mobile Menu Overlay -->
                <div id="services-menu-overlay" class="fixed inset-0 bg-[#fdfaf5] z-50 flex flex-col items-center justify-center translate-y-[-100%] transition-transform duration-500 ease-in-out md:hidden">
                    <nav class="flex flex-col items-center gap-8 text-[24px] font-normal tracking-wide text-[#2c2c2c] mb-12">
                        <a href="/" class="services-mobile-link hover:text-[#9c512c] transition-colors">Home</a>
                        <a href="/about" class="services-mobile-link hover:text-[#9c512c] transition-colors">About</a>
                        <a href="/services" class="services-mobile-link hover:text-[#9c512c] transition-colors">Services</a>
                        <a href="/journal" class="services-mobile-link hover:text-[#9c512c] transition-colors">Journal</a>
                    </nav>
                    <Button href="/contact" variant="primary" className="!px-8 !py-[12px] !text-[15px] tracking-wide">Begin Your Journey</Button>
                </div>
            </header>

            <!-- HERO CONTENT -->
            <main class="w-full flex flex-col items-center justify-center text-center px-6 relative z-20" style="padding-top: 100px;">
                
                <!-- Badge -->
                <span class="inline-block font-medium tracking-wide rounded-full shadow-sm" style="background-color: #9c512c; color: white; padding: 6px 20px; font-size: 12px; margin-bottom: 32px;">
                    Services
                </span>
                
                <!-- Headline -->
                <h1 class="font-serif font-normal" style="color: #2c3338; font-size: clamp(48px, 8vw, 82px); line-height: 0.98; letter-spacing: -0.02em; margin-bottom: 24px;">
                    Guiding you<br/>
                    back to <span style="color: #9c512c;">balance.</span>
                </h1>
                
                <!-- Subtitle -->
                <p class="font-light" style="color: #55524d; font-size: 16px; line-height: 1.65; max-width: 500px;">
                    I work with people dealing with stress, burnout, and the feeling that<br class="hidden md:block"/>
                    something needs to change but they're not sure where to start.
                </p>
                
            </main>
        </div>

        <!-- WHAT I HELP WITH SECTION -->
        <section class="w-full text-center flex flex-col items-center px-6" style="background-color: #fcfbfa; padding-top: 120px; padding-bottom: 120px;">
            
            <!-- Badge -->
            <div style="margin-bottom: 24px;">
                <span class="inline-block font-medium tracking-wide uppercase rounded-full" style="background-color: #f0eae1; color: #55524d; font-size: 12px; padding: 8px 20px;">
                    What I help with
                </span>
            </div>
            
            <!-- Heading -->
            <h2 class="font-sans font-medium" style="color: #282725; font-size: clamp(36px, 5vw, 48px); line-height: 1.05; letter-spacing: -0.03em; margin-bottom: 16px;">
                Four areas with <span style="color: #9c512c;">one approach.</span>
            </h2>
            
            <!-- Subtitle -->
            <p class="font-light" style="color: #68625d; font-size: 15.5px; line-height: 1.65; margin-bottom: 80px;">
                You don't need to fit into a box. Most of the people<br class="hidden md:block" /> I work with are dealing with a mix of these.
            </p>

            <!-- Cards Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 w-full mx-auto text-left" style="gap: 32px; max-width: 1040px;">
                
                <!-- Card 1: Stress & Anxiety -->
                <div class="flex flex-col" style="background-color: #f1eae1; border-radius: 16px; overflow: hidden;">
                    <div class="relative w-full" style="height: 270px;">
                        <Image src={imgStress} alt="Stress and Anxiety" class="absolute inset-0 w-full h-full object-cover" />
                    </div>
                    <div class="flex flex-col items-start w-full" style="padding: 28px 24px 34px 24px;">
                        <h3 class="font-medium" style="color: #282725; font-size: 20px; letter-spacing: -0.01em; margin-bottom: 14px;">Stress & Anxiety</h3>
                        <p class="font-light" style="color: #635f5a; font-size: 14.5px; line-height: 1.65; margin-bottom: 24px;">
                            When your mind won't switch off and your body's stuck in fight-or-flight. We work on calming your nervous system and building a life that doesn't constantly overwhelm you.
                        </p>
                        <ul class="flex flex-col" style="gap: 12px; list-style: none; padding: 0; margin: 0; width: 100%;">
                            <li class="flex items-start font-light" style="gap: 10px; color: #635f5a; font-size: 13.5px; line-height: 1.4;">
                                <span style="color: #9c512c; font-size: 15px;">&rarr;</span> Nervous system regulation
                            </li>
                            <li class="flex items-start font-light" style="gap: 10px; color: #635f5a; font-size: 13.5px; line-height: 1.4;">
                                <span style="color: #9c512c; font-size: 15px;">&rarr;</span> Breathing and grounding techniques
                            </li>
                            <li class="flex items-start font-light" style="gap: 10px; color: #635f5a; font-size: 13.5px; line-height: 1.4;">
                                <span style="color: #9c512c; font-size: 15px;">&rarr;</span> Sustainable stress management
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Card 2: Burnout recovery -->
                <div class="flex flex-col" style="background-color: #f1eae1; border-radius: 16px; overflow: hidden;">
                    <div class="relative w-full" style="height: 270px;">
                         <Image src={imgBurnout} alt="Burnout recovery" class="absolute inset-0 w-full h-full object-cover" />
                    </div>
                    <div class="flex flex-col items-start w-full" style="padding: 28px 24px 34px 24px;">
                        <h3 class="font-medium" style="color: #282725; font-size: 20px; letter-spacing: -0.01em; margin-bottom: 14px;">Burnout recovery</h3>
                        <p class="font-light" style="color: #635f5a; font-size: 14.5px; line-height: 1.65; margin-bottom: 24px;">
                            You pushed too hard for too long and now you're running on empty. We rebuild from the ground up, starting with rest and working toward a routine that doesn't break you again.
                        </p>
                        <ul class="flex flex-col" style="gap: 12px; list-style: none; padding: 0; margin: 0; width: 100%;">
                            <li class="flex items-start font-light" style="gap: 10px; color: #635f5a; font-size: 13.5px; line-height: 1.4;">
                                <span style="color: #9c512c; font-size: 15px;">&rarr;</span> Rest and recovery planning
                            </li>
                            <li class="flex items-start font-light" style="gap: 10px; color: #635f5a; font-size: 13.5px; line-height: 1.4;">
                                <span style="color: #9c512c; font-size: 15px;">&rarr;</span> Boundary setting
                            </li>
                            <li class="flex items-start font-light" style="gap: 10px; color: #635f5a; font-size: 13.5px; line-height: 1.4;">
                                <span style="color: #9c512c; font-size: 15px;">&rarr;</span> Rebuilding sustainable routines
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Card 3: Life transitions -->
                <div class="flex flex-col" style="background-color: #f1eae1; border-radius: 16px; overflow: hidden;">
                    <div class="relative w-full" style="height: 270px;">
                         <Image src={imgTransitions} alt="Life transitions" class="absolute inset-0 w-full h-full object-cover" />
                    </div>
                    <div class="flex flex-col items-start w-full" style="padding: 28px 24px 34px 24px;">
                        <h3 class="font-medium" style="color: #282725; font-size: 20px; letter-spacing: -0.01em; margin-bottom: 14px;">Life transitions</h3>
                        <p class="font-light" style="color: #635f5a; font-size: 14.5px; line-height: 1.65; margin-bottom: 24px;">
                            Career changes, relationship shifts, becoming a parent, moving countries. The big life moments that leave you feeling unsteady. We work through the adjustment together.
                        </p>
                        <ul class="flex flex-col" style="gap: 12px; list-style: none; padding: 0; margin: 0; width: 100%;">
                            <li class="flex items-start font-light" style="gap: 10px; color: #635f5a; font-size: 13.5px; line-height: 1.4;">
                                <span style="color: #9c512c; font-size: 15px;">&rarr;</span> Navigating uncertainty
                            </li>
                            <li class="flex items-start font-light" style="gap: 10px; color: #635f5a; font-size: 13.5px; line-height: 1.4;">
                                <span style="color: #9c512c; font-size: 15px;">&rarr;</span> Identity and confidence rebuilding
                            </li>
                            <li class="flex items-start font-light" style="gap: 10px; color: #635f5a; font-size: 13.5px; line-height: 1.4;">
                                <span style="color: #9c512c; font-size: 15px;">&rarr;</span> Creating stability in change
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Card 4: Mindful living -->
                <div class="flex flex-col" style="background-color: #f1eae1; border-radius: 16px; overflow: hidden;">
                    <div class="relative w-full" style="height: 270px;">
                         <Image src={imgMindful} alt="Mindful living" class="absolute inset-0 w-full h-full object-cover" />
                    </div>
                    <div class="flex flex-col items-start w-full" style="padding: 28px 24px 34px 24px;">
                        <h3 class="font-medium" style="color: #282725; font-size: 20px; letter-spacing: -0.01em; margin-bottom: 14px;">Mindful living</h3>
                        <p class="font-light" style="color: #635f5a; font-size: 14.5px; line-height: 1.65; margin-bottom: 24px;">
                            For people who want to be more intentional about how they live. We look at habits, routines, and boundaries so you actually enjoy your days instead of just getting through them.
                        </p>
                        <ul class="flex flex-col" style="gap: 12px; list-style: none; padding: 0; margin: 0; width: 100%;">
                            <li class="flex items-start font-light" style="gap: 10px; color: #635f5a; font-size: 13.5px; line-height: 1.4;">
                                <span style="color: #9c512c; font-size: 15px;">&rarr;</span> Daily habits and routines
                            </li>
                            <li class="flex items-start font-light" style="gap: 10px; color: #635f5a; font-size: 13.5px; line-height: 1.4;">
                                <span style="color: #9c512c; font-size: 15px;">&rarr;</span> Healthy boundaries
                            </li>
                            <li class="flex items-start font-light" style="gap: 10px; color: #635f5a; font-size: 13.5px; line-height: 1.4;">
                                <span style="color: #9c512c; font-size: 15px;">&rarr;</span> Intentional living practices
                            </li>
                        </ul>
                    </div>
                </div>

            </div>
        </section>

        <!-- WHAT TO EXPECT SECTION -->
        <WhatToExpect />

        <!-- PROGRAMS SECTION -->
        <ProgramsSection />

        <!-- FAQ SECTION -->
        <FAQSection />

        <!-- FOOTER -->
        <Footer />

        <!-- STICKY HEADER SCRIPT -->
        <script is:inline>
            (function () {
                var header = document.getElementById('services-header');
                var toggleBtn = document.getElementById('services-menu-toggle');
                var mobileMenu = document.getElementById('services-menu-overlay');
                var isMenuOpen = false;

                function toggleMenu() {
                    isMenuOpen = !isMenuOpen;
                    if (isMenuOpen) {
                        mobileMenu.style.transform = 'translateY(0)';
                        document.body.style.overflow = 'hidden';
                        toggleBtn.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2c2c2c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>';
                    } else {
                        mobileMenu.style.transform = 'translateY(-100%)';
                        document.body.style.overflow = '';
                        toggleBtn.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="8" x2="20" y2="8"></line><line x1="4" y1="16" x2="20" y2="16"></line></svg>';
                    }
                }
                if (toggleBtn) toggleBtn.addEventListener('click', toggleMenu);
                document.querySelectorAll('.services-mobile-link').forEach(function(link) {
                    link.addEventListener('click', function() { if (isMenuOpen) toggleMenu(); });
                });

                function onScroll() {
                    if (isMenuOpen) return;
                    if (window.scrollY > 50) {
                        header.style.background = 'rgba(244, 235, 217, 0.96)';
                        header.style.backdropFilter = 'blur(12px)';
                        header.style.WebkitBackdropFilter = 'blur(12px)';
                        header.style.boxShadow = '0 4px 30px rgba(0,0,0,0.03)';
                        header.style.paddingTop = '18px';
                        header.style.paddingBottom = '18px';
                    } else {
                        header.style.background = 'transparent';
                        header.style.backdropFilter = 'none';
                        header.style.WebkitBackdropFilter = 'none';
                        header.style.boxShadow = 'none';
                        header.style.paddingTop = '32px';
                        header.style.paddingBottom = '24px';
                    }
                }
                window.addEventListener('scroll', onScroll, { passive: true });
                onScroll();
            })();
        </script>
	</body>
</html>
